# Copy to .env and replace placeholders with local values. Do not commit secrets.

# Convex
# <your-convex-http-url>
CONVEX_URL=
# <your-convex-deployment-url>
VITE_CONVEX_URL=

# LLM providers
# <your-openrouter-api-key>
OPENROUTER_API_KEY=
# <your-openrouter-base-url>
OPENROUTER_BASE_URL=
# <your-openrouter-default-model>
OPENROUTER_DEFAULT_MODEL=
# <your-openrouter-model>
OPENROUTER_MODEL=
# <your-openrouter-chat-model>
OPENROUTER_CHAT_MODEL=

# Paper sources
# <your-semantic-scholar-api-key>
SEMANTIC_SCHOLAR_API_KEY=
# <your-semantic-scholar-base-url>
SEMANTIC_SCHOLAR_BASE_URL=

# HaluGate
# <your-halugate-url>
HALUGATE_URL=

# Runtime
# <your-model-profile>
MODEL_PROFILE=
# <your-log-level>
LOG_LEVEL=
# <your-arxiv-rate-limit-seconds>
ARXIV_RATE_LIMIT_SECONDS=
